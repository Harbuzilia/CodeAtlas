{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "instructions.md"
  ],
  "model": "google/antigravity-gemini-3-pro:high",
  "small_model": "google/antigravity-gemini-3-flash",
  "default_agent": "openagent",
  "permission": {
    "bash": {
      "*": "ask",
      "git status": "allow",
      "git status *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git log*": "allow",
      "git branch*": "allow",
      "git remote*": "allow",
      "ls": "allow",
      "ls *": "allow",
      "pwd": "allow",
      "python --version": "allow",
      "node --version": "allow",
      "npm list": "allow",
      "npm list *": "allow",
      "grep *": "allow",
      "find *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "rm *": "deny",
      "rm -rf *": "deny"
    },
    "edit": {
      "**/*.env*": "deny",
      "**/*.key": "deny",
      "**/*.secret": "deny",
      ".git/**": "deny",
      "node_modules/**": "deny"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "external_directory": {
      "D:/AllMyProject/**": "allow"
    },
    "doom_loop": "ask",
    "skill": "allow",
    "task": "allow"
  },
  "provider": {
    "google": {
      "npm": "@ai-sdk/google",
      "models": {
        "antigravity-gemini-3-pro": {
          "name": "Gemini 3 Pro (Antigravity)",
          "limit": {
            "context": 1048576,
            "output": 65535
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "low": {
              "thinkingLevel": "low"
            },
            "high": {
              "thinkingLevel": "high"
            }
          }
        },
        "antigravity-gemini-3-flash": {
          "name": "Gemini 3 Flash (Antigravity)",
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "minimal": {
              "thinkingLevel": "minimal"
            },
            "low": {
              "thinkingLevel": "low"
            },
            "medium": {
              "thinkingLevel": "medium"
            },
            "high": {
              "thinkingLevel": "high"
            }
          }
        },
        "antigravity-claude-sonnet-4-5": {
          "name": "Claude Sonnet 4.5 (Antigravity)",
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          }
        },
        "antigravity-claude-sonnet-4-5-thinking": {
          "name": "Claude Sonnet 4.5 Thinking (Antigravity)",
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "low": {
              "thinkingConfig": {
                "thinkingBudget": 8192
              }
            },
            "max": {
              "thinkingConfig": {
                "thinkingBudget": 32768
              }
            }
          }
        },
        "antigravity-claude-opus-4-5-thinking": {
          "name": "Claude Opus 4.5 Thinking (Antigravity)",
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "low": {
              "thinkingConfig": {
                "thinkingBudget": 8192
              }
            },
            "max": {
              "thinkingConfig": {
                "thinkingBudget": 32768
              }
            }
          }
        },
        "antigravity-gpt-oss-120b": {
          "name": "GPT-OSS 120B"
        }
      }
    }
  },
  "agent": {
    "openagent": {
      "path": "agents/openagent.md",
      "color": "primary"
    },
    "contextscout": {
      "path": "agents/contextscout.md",
      "color": "#00BCD4"
    },
    "coder": {
      "path": "agents/coder.md",
      "color": "#4CAF50"
    },
    "tester": {
      "path": "agents/tester.md",
      "color": "#9C27B0"
    },
    "reviewer": {
      "path": "agents/reviewer.md",
      "color": "#2196F3"
    },
    "debugger": {
      "path": "agents/debugger.md",
      "color": "#FF5722"
    },
    "planner": {
      "path": "agents/planner.md",
      "color": "#FF9800"
    },
    "externalscout": {
      "path": "agents/externalscout.md",
      "color": "#607D8B"
    },
    "docwriter": {
      "path": "agents/docwriter.md",
      "color": "#795548"
    },
    "uitester": {
      "path": "agents/uitester.md",
      "color": "#E91E63"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "ddg-search": {
      "type": "local",
      "command": [
        "uvx",
        "duckduckgo-mcp-server"
      ],
      "timeout": 30
    },
    "github-grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    },
    "echovault": {
      "type": "local",
      "command": [
        "memory",
        "mcp"
      ]
    }
  },
  "plugin": [
    "opencode-antigravity-auth@beta",
    "@tarquinen/opencode-dcp@latest"
  ]
}
