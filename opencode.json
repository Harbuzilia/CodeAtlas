{
    "$schema": "https://opencode.ai/config.json",
    "instructions": [
        "instructions.md"
    ],
    "model": "openrouter/claude-3.5-sonnet",
    "small_model": "openrouter/gpt-4o-mini",
    "default_agent": "openagent",
    "permission": {
        "bash": {
            "git status": "allow",
            "ls": "allow",
            "pwd": "allow",
            "git diff": "allow",
            "python --version": "allow",
            "npm list": "allow",
            "*": "ask"
        },
        "edit": {
            "**/*.env*": "deny",
            ".git/**": "deny"
        }
    },
    "provider": {
        "openrouter": {
            "npm": "@openrouter/ai-sdk-provider",
            "options": {
                "apiKey": "YOUR_OPENROUTER_API_KEY"
            },
            "models": {
                "claude-3.5-sonnet": {
                    "name": "Claude 3.5 Sonnet",
                    "limit": {
                        "context": 200000,
                        "output": 8192
                    },
                    "modalities": {
                        "input": [
                            "text",
                            "image"
                        ],
                        "output": [
                            "text"
                        ]
                    }
                },
                "gpt-4o-mini": {
                    "name": "GPT 4o Mini",
                    "limit": {
                        "context": 128000,
                        "output": 4096
                    },
                    "modalities": {
                        "input": [
                            "text",
                            "image"
                        ],
                        "output": [
                            "text"
                        ]
                    }
                }
            }
        }
    },
    "agent": {
        "openagent": {
            "path": "agents/openagent.md"
        },
        "contextscout": {
            "path": "agents/contextscout.md"
        },
        "coder": {
            "path": "agents/coder.md"
        },
        "reviewer": {
            "path": "agents/reviewer.md"
        },
        "planner": {
            "path": "agents/planner.md"
        },
        "tester": {
            "path": "agents/tester.md"
        }
    },
    "mcp": {
        "context7": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@upstash/context7-mcp"
            ]
        },
        "tavily-search": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@tavily/mcp-server"
            ],
            "env": {
                "TAVILY_API_KEY": "YOUR_TAVILY_API_KEY"
            }
        },
        "github-grep": {
            "type": "remote",
            "url": "https://mcp.grep.app"
        }
    }
}